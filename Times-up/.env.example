# ==============================================================================
# TIME'S UP - PARENTAL CONTROL SYSTEM ENVIRONMENT CONFIGURATION
# ==============================================================================

# APP_URL: The hosting URL 
APP_URL="http://localhost:3000"

# JWT_SECRET: Security token signature key for parents' login and dashboard sessions
JWT_SECRET="times_up_parental_control_jwt_secret_key_9988"

# ENCRYPTION_KEY: Secret key used to encrypt child's private details (SMS bodies & Call Logs)
# It MUST be a 32-character string for AES-256-GCM.
ENCRYPTION_KEY="times_up_parental_secret_key_32_bytes_long"

# DATABASE SETTINGS (Used during local Docker Compose deployment)
DB_HOST="localhost"
DB_USER="parent_admin"
DB_PASSWORD="secure_mysql_password_123"
DB_NAME="times_up"
DB_PORT=3306

# GEMINI_API_KEY (Optional - injected automatically if requested)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE MAPS PLATFORM KEY
GOOGLE_MAPS_PLATFORM_KEY=""
VITE_GOOGLE_MAPS_PLATFORM_KEY=""
